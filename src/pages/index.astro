---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', ({ data }) => !data.draft);
articles.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const featured = articles.slice(0, 8);
const categories = [
    { slug: 'applications', name: 'Applications', desc: 'Applications' },
    { slug: 'financial-aid', name: 'Financial Aid', desc: 'Financial Aid' },
    { slug: 'scholarships', name: 'Scholarships', desc: 'Scholarships' },
    { slug: 'standardized-tests', name: 'Tests & Scores', desc: 'Tests & Scores' },
    { slug: 'campus-life', name: 'Campus Life', desc: 'Campus Life' },
];

const homeSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'College FAQ',
  url: 'https://faq.college',
  description: 'Comprehensive guides and answers to the most common questions about college applications, admissions, financial aid, scholarships, and campus life.',
  inLanguage: 'en',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://faq.college/?q={{search_term_string}}',
    'query-input': 'required name=search_term_string',
  },
});
---

<BaseLayout
  title="College FAQ"
  description="Comprehensive guides and answers to the most common questions about college applications, admissions, financial aid, scholarships, and campus life."
  schema={homeSchema}
>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-12 text-center">
    <p class="chapter-num text-aus-green text-lg mb-3">I</p>
    <h1 class="font-heading text-4xl md:text-5xl text-aus-ink font-bold leading-tight mb-4">
      College FAQ
    </h1>
    <p class="text-xl text-aus-muted mb-6 font-heading">
      Straight answers to your college questions
    </p>
    <p class="max-w-2xl mx-auto text-aus-muted leading-relaxed">
      Applying to college is complicated. We provide clear, well-researched answers to the most common questions about applications, essays, standardized tests, financial aid, scholarships, and everything in between. No marketing fluff — just facts.
    </p>
  </section>

  <!-- Categories -->
  <section class="max-w-5xl mx-auto px-6 pb-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {categories.map(cat => (
        <a
          href={`/category/${cat.slug}/`}
          class="block p-5 border border-aus-green/10 rounded-sm hover:border-aus-red/30 hover:bg-white/50 transition-colors no-underline group"
        >
          <h2 class="font-heading text-lg text-aus-ink font-bold group-hover:text-aus-red transition-colors">{cat.name}</h2>
          <p class="text-sm text-aus-muted mt-1">{cat.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Featured Articles -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <h2 class="font-heading text-2xl text-aus-ink font-bold mb-8">Latest Analysis</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {featured.map(article => (
        <a
          href={`/${article.id}/`}
          class="block p-6 border border-aus-green/10 rounded-sm hover:border-aus-red/30 hover:bg-white/50 transition-colors no-underline group"
        >
          <span class="text-xs text-aus-green uppercase tracking-wide">{article.data.category}</span>
          <h3 class="font-heading text-xl text-aus-ink font-bold mt-1 mb-2 group-hover:text-aus-red transition-colors">{article.data.title}</h3>
          <p class="text-sm text-aus-muted leading-relaxed">{article.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
