---
import BaseLayout from '../layouts/BaseLayout.astro';

const aboutSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About College FAQ',
  url: 'https://faq.college/about/',
  description: 'Comprehensive guides and answers to the most common questions about college applications, admissions, financial aid, scholarships, and campus life.',
  publisher: {
    '@type': 'Organization',
    name: 'College FAQ Editorial',
  },
});
---

<BaseLayout
  title="About College FAQ"
  description="Comprehensive guides and answers to the most common questions about college applications, admissions, financial aid, scholarships, and campus life."
  schema={aboutSchema}
>
  <article class="max-w-editorial mx-auto px-6 py-12">
    <h1 class="font-heading text-3xl md:text-4xl text-aus-ink font-bold mb-8">About College FAQ</h1>

    <div class="prose prose-lg max-w-none">
<section class="mb-10">
        <h2 class="font-heading text-2xl text-aus-ink font-bold">Our Mission</h2>
        <p>
          The college application process is overwhelming — especially for first-generation students and international applicants who don't have family experience to draw on. Our mission is to provide <strong>clear, factual answers</strong> to the questions everyone asks but few sources answer directly.
        </p>
        <p>
          From FAFSA changes to essay mistakes to scholarship deadlines, we break down complex topics into actionable guidance based on official sources and institutional policies.
        </p>
      </section>
      <section class="mb-10">
        <h2 class="font-heading text-2xl text-aus-ink font-bold">What We Cover</h2>
        <ul>
          <li>College application process: Common App, deadlines, essays, recommendations</li>
          <li>Financial aid: FAFSA, CSS Profile, grants, loans, work-study</li>
          <li>Scholarships: merit-based, need-based, international student opportunities</li>
          <li>Standardized tests: SAT, ACT, TOEFL, IELTS — what scores you need</li>
          <li>Campus life: housing, dining, clubs, mental health resources</li>
        </ul>
      </section>
      <section class="mb-10">
        <h2 class="font-heading text-2xl text-aus-ink font-bold">Editorial Standards</h2>
        <p>
          All guidance is based on official sources: university admissions offices, College Board, U.S. Department of Education, and institutional financial aid policies. We verify information against primary sources and update content when policies change.
        </p>
      </section>
    </div>
  </article>
</BaseLayout>
