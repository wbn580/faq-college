---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isPublicArticle } from '../../utils/publicArticles';

export async function getStaticPaths() {
  return [
    { params: { cat: 'applications' } },
    { params: { cat: 'financial-aid' } },
    { params: { cat: 'scholarships' } },
    { params: { cat: 'standardized-tests' } },
    { params: { cat: 'campus-life' } },
  ];
}

const { cat } = Astro.params;
const catNames = {
  'applications': 'Applications',
  'financial-aid': 'Financial Aid',
  'scholarships': 'Scholarships',
  'standardized-tests': 'Tests & Scores',
  'campus-life': 'Campus Life',
};
const catName = catNames[cat] || cat;

const categoryAliases = {
  'applications': ['applications', 'apply', 'application', 'admissions', 'how', 'common'],
  'financial-aid': ['financial-aid', 'financial aid', 'cost', 'tuition', 'fafsa', 'loan'],
  'scholarships': ['scholarships', 'scholarship'],
  'standardized-tests': ['standardized-tests', 'tests', 'test', 'sat', 'act', 'ap'],
  'campus-life': ['campus-life', 'campus life', 'dorm', 'housing', 'life'],
};

const aliases = categoryAliases[cat] || [cat];
const articles = (await getCollection('articles')).filter(article => {
  const data = article.data;
  const category = String(data.category || '').toLowerCase();
  const title = String(data.title || '').toLowerCase();
  return isPublicArticle(article) && aliases.some(alias => category === alias || title.includes(alias.replace('-', ' ')));
});
articles.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
---

<BaseLayout
  title={`${catName} · College FAQ`}
  description={`Latest College FAQ articles in ${catName}.`}
>
  <div class="max-w-5xl mx-auto px-6 py-12">
    <h1 class="font-heading text-3xl text-aus-ink font-bold mb-4">{catName}</h1>
    <p class="text-aus-muted mb-8">{articles.length} articles</p>
    <div class="space-y-4">
      {articles.map(article => (
        <a
          href={`/${article.id}/`}
          class="block p-5 border border-aus-green/10 rounded-sm hover:border-aus-red/30 transition-colors no-underline group"
        >
          <h2 class="font-heading text-xl text-aus-ink font-bold group-hover:text-aus-red transition-colors">{article.data.title}</h2>
          <p class="text-sm text-aus-muted mt-1">{article.data.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
