---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  return [
    { params: { cat: 'geography' } },
    { params: { cat: 'history' } },
    { params: { cat: 'politics' } },
    { params: { cat: 'economy' } },
    { params: { cat: 'education' } },
    { params: { cat: 'culture' } },
  ];
}

const { cat } = Astro.params;
const catNames = {
  geography: '地理', history: '历史', politics: '政治',
  economy: '经济', education: '教育', culture: '文化',
};
const catName = catNames[cat] || cat;

const articles = await getCollection('articles', ({ data }) => data.category === cat && !data.draft);
articles.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
---

<BaseLayout
  title={`${catName} · 澳洲百科`}
  description={`澳洲百科 ${catName} 模块——全部条目按时间倒序排列。`}
>
  <div class="max-w-5xl mx-auto px-6 py-12">
    <h1 class="font-heading text-3xl text-aus-ink font-bold mb-4">{catName}</h1>
    <p class="text-aus-muted mb-8">共 {articles.length} 篇</p>
    <div class="space-y-4">
      {articles.map(article => (
        <a
          href={`/${article.slug}/`}
          class="block p-5 border border-aus-green/10 rounded-sm hover:border-aus-red/30 transition-colors no-underline group"
        >
          <h2 class="font-heading text-xl text-aus-ink font-bold group-hover:text-aus-red transition-colors">{article.data.title}</h2>
          <p class="text-sm text-aus-muted mt-1">{article.data.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
