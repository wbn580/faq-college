---
import BaseHead from '../components/BaseHead.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
  schema?: string;
}

const {
  title,
  description,
  ogImage,
  canonicalURL,
  schema,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      ogImage={ogImage}
      canonicalURL={canonicalURL}
      schema={schema}
    />
    <style is:global>
      @import '../styles/global.css';
    </style>
      <!-- Unified lead conversion entry: assessment form, chat, sticky buttons, and in-article cards -->
    <script src="https://chat.faq.college/lead.js?v=20260702-routefix" data-site="faq-college" data-lang="en" data-tier="country" data-country="us" data-apply-base="https://apply.faq.college" data-color="#d98c5f" data-accent="#1f6b3a" async></script>
    <!-- Chat widget for lead consultation actions -->
    <script src="https://chat.faq.college/assistant.js" data-site="faq-college" data-lang="en" data-bot-name="College FAQ Assistant" data-channel="organic" data-color="#d98c5f" data-accent="#1f6b3a" async data-no-bubble="1"></script>
</head>
  <body>
    <!-- Nav: centered-overlay (logo center, links flanking) -->
    <nav class="nav" id="nav">
      <div class="row left"><a href="#dim">Topics</a><a href="#articles">Latest</a></div>
      <a href="/" class="brand">College FAQ Desk<small>Straight Answers</small></a>
      <div class="row right"><a href="/about/">About</a><a href="/about/">Ask</a></div>
      <div class="hamb"><span></span><span></span><span></span></div>
    </nav>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer>
      <div class="foot-grid">
        <div class="foot-brand">
          <b>College FAQ Desk</b>
          <p>Straight answers to your college questions — no marketing fluff, just well-researched facts about applications, financial aid, scholarships, and campus life.</p>
        </div>
        <div>
          <h4>Topics</h4>
          <a href="/category/applications/">Applications</a>
          <a href="/category/financial-aid/">Financial Aid</a>
          <a href="/category/scholarships/">Scholarships</a>
          <a href="/category/standardized-tests/">Tests &amp; Scores</a>
          <a href="/category/campus-life/">Campus Life</a>
        </div>
        <div>
          <h4>Resources</h4>
          <a href="/about/">About</a>
          <a href="#dim">Categories</a>
          <a href="#articles">Latest Articles</a>
        </div>
        <div>
          <h4>Info</h4>
          <a href="/about/">About Us</a>
          <a href="/about/">Contact</a>
        </div>
      </div>
      <div class="foot-bottom">
        <span>&copy; 2026 College FAQ Desk. Independent educational resource.</span>
        <span>Not affiliated with any university.</span>
      </div>
    </footer>
<!-- Chat widget -->
        <!-- Centralized lead entry: sticky buttons, desktop pill, and in-article cards -->
</body>
</html>
