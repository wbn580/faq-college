---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  publishDate: string;
  category: string;
  readingTime?: number;
  ogImage?: string;
  sources?: Array<{ title: string; url: string; type: string }>;
}

const {
  title,
  description,
  publishDate,
  category,
  readingTime,
  ogImage,
} = Astro.props;

const siteUrl = 'https://faq.college';
const slug = Astro.url.pathname;
const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  datePublished: publishDate,
  dateModified: publishDate,
  author: {
    '@type': 'Organization',
    name: 'College FAQ',
  },
  publisher: {
    '@type': 'Organization',
    name: 'College FAQ',
    url: siteUrl,
  },
  articleSection: category,
});
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  canonicalURL={`${siteUrl}${slug}`}
  schema={articleSchema}
>
  <article class="article-page">
    <header>
      <nav class="breadcrumbs">
        <a href="/">Home</a> /
        <a href={`/category/${category}/`}> {category}</a> /
        <span>{title}</span>
      </nav>
      <h1 class="article-title">{title}</h1>
      <div class="article-meta">
        <time datetime={publishDate}>{new Date(publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        {readingTime && <span>{readingTime} min read</span>}
      </div>
    </header>

    <div class="article-body">
      <slot />
    </div>

    <footer class="article-footer">
      <a href="/">&larr; Back to Home</a>
      <a href={`/category/${category}/`}>More in {category} &rarr;</a>
    </footer>
  </article>
</BaseLayout>
