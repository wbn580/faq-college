---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  publishDate: string;
  category: string;
  readingTime?: number;
  ogImage?: string;
  sources?: Array<{ title: string; url: string; type: string }>;
}

const {
  title,
  description,
  publishDate,
  category,
  readingTime,
  ogImage,
} = Astro.props;

const siteUrl = 'https://aus.wiki';
const slug = Astro.url.pathname;
const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  datePublished: publishDate,
  dateModified: publishDate,
  author: {
    '@type': 'Organization',
    name: '澳洲百科 · UNILINK 研究案头',
  },
  publisher: {
    '@type': 'Organization',
    name: '澳洲百科',
    url: siteUrl,
  },
  articleSection: category,
});
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  canonicalURL={`${siteUrl}${slug}`}
  schema={articleSchema}
>
  <article class="max-w-editorial mx-auto px-6 py-12">
    <header class="mb-10">
      <nav class="text-sm text-aus-muted mb-4">
        <a href="/" class="hover:text-aus-red no-underline">首页</a> /
        <a href={`/category/${category}/`} class="hover:text-aus-red no-underline"> {category === 'geography' ? '地理' : category === 'history' ? '历史' : category === 'politics' ? '政治' : category === 'economy' ? '经济' : category === 'education' ? '教育' : '文化'}</a> /
        <span class="text-aus-ink">{title}</span>
      </nav>
      <h1 class="font-heading text-3xl md:text-4xl text-aus-ink font-bold leading-tight mb-4">
        {title}
      </h1>
      <div class="flex items-center gap-4 text-sm text-aus-muted">
        <time datetime={publishDate}>{new Date(publishDate).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        {readingTime && <span>{readingTime} 分钟阅读</span>}
      </div>
    </header>

    <div class="prose prose-lg prose-aus-ink max-w-none">
      <slot />
    </div>

    <footer class="mt-16 pt-8 border-t border-aus-green/15">
      <nav class="flex justify-between text-sm">
        <a href="/" class="text-aus-green hover:text-aus-red no-underline">← 返回首页</a>
        <a href={`/category/${category}/`} class="text-aus-green hover:text-aus-red no-underline">
          更多{category === 'geography' ? '地理' : category === 'history' ? '历史' : category === 'politics' ? '政治' : category === 'economy' ? '经济' : category === 'education' ? '教育' : '文化'}文章 →
        </a>
      </nav>
    </footer>
  </article>
</BaseLayout>
