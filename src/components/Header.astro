---
const categories = [
    { slug: "applications", name: "Applications" },
    { slug: "financial-aid", name: "Financial Aid" },
    { slug: "scholarships", name: "Scholarships" },
    { slug: "standardized-tests", name: "Tests & Scores" },
    { slug: "campus-life", name: "Campus Life" },
];
---

<header class="border-b border-aus-green/15 bg-aus-sand/95 backdrop-blur-sm sticky top-0 z-10">
  <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="font-heading text-2xl text-aus-red font-bold tracking-wide no-underline">
      College FAQ
    </a>
    <div class="hidden md:flex gap-1 text-sm">
      {categories.map(cat => (
        <a
          href={`/category/${cat.slug}/`}
          class="px-3 py-1.5 text-aus-muted hover:text-aus-ink hover:bg-aus-green/5 rounded-sm transition-colors no-underline"
        >
          {cat.name}
        </a>
      ))}
    </div>
    <a href="/about/" class="text-sm text-aus-muted hover:text-aus-ink no-underline hidden md:block">
      About
    </a>
  </nav>
</header>
