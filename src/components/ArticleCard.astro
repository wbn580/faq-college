---
const { entry } = Astro.props as { entry: any };
---
<details class="bg-white border border-primary/10 rounded-lg p-4 mb-3 cursor-pointer">
  <summary class="font-heading text-lg font-semibold">{entry.data.title}</summary>
  <div class="mt-3 text-sm text-muted"><p>{entry.data.description}</p><p class="mt-2"><a href={`/${entry.id}/`} class="text-accent">Read full →</a></p></div>
</details>