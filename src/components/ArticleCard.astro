---
const { entry } = Astro.props as { entry: any };
---
<a href={`/${entry.id}/`} class="post">
  <div class="thumb">
    {entry.data.image ? (
      <img src={entry.data.image} alt="" loading="lazy" />
    ) : (
      <div class="placeholder-icon">{['📝','💰','🎓','📊','🏛️'][Math.floor(Math.random() * 5)]}</div>
    )}
    <span class="cat">{entry.data.category || 'Article'}</span>
  </div>
  <div class="body">
    <h3>{entry.data.title}</h3>
    <p>{entry.data.description}</p>
    <div class="meta">
      College FAQ
      <span class="dot"></span>
      {entry.data.publishDate ? new Date(entry.data.publishDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : ''}
    </div>
  </div>
</a>
